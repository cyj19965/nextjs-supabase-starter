{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/protect-env.cjs",
            "timeout": 10,
            "statusMessage": "Checking protected files..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/format.cjs",
            "timeout": 60,
            "statusMessage": "Formatting with Prettier..."
          }
        ]
      }
    ]
  }
}
